{
  "manifest_version": 2,
  "name": "Iceraven Navigation Guard",
  "version": "0.1.1",
  "description": "Firefox-first navigation guard to reduce unwanted redirects, popups, and history pollution.",
  "permissions": [
    "webRequest",
    "webRequestBlocking",
    "webNavigation",
    "tabs",
    "storage",
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "scripts": [
      "src/background/defaults.js",
      "src/background/storage.js",
      "src/background/logger.js",
      "src/background/policy.js",
      "src/background/approval.js",
      "src/background/background.js"
    ]
  },
  "options_ui": {
    "page": "src/ui/options.html",
    "open_in_tab": true
  },
  "browser_action": {
    "default_title": "Navigation Guard",
    "default_popup": "src/ui/popup.html"
  },
  "web_accessible_resources": [
    "src/content/inpage-hook.js"
  ],
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": ["src/content/content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}
